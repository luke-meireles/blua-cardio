# BluaDiagnostics / blua-cardio — variáveis de ambiente
#
# Copie este arquivo para .env e preencha os valores.
# NUNCA commitar .env para o Git (.gitignore já bloqueia).

# ================================================================
# LLM (obrigatório)
# ================================================================
# Backend: 'dashscope' (cloud, default) ou 'ollama' (local)
LLM_BACKEND=dashscope

# DashScope International — https://dashscope-intl.console.alibabacloud.com
# Free tier: $10 de boas-vindas
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
QWEN_DASHSCOPE_MODEL=qwen-plus

# Ollama (local, LGPD-friendly) — só usado se LLM_BACKEND=ollama
# Requer Ollama >= 0.3.0 + `ollama pull qwen2.5:14b`
# Nota: o código passa api_key="ollama" hardcoded — não defina OLLAMA_API_KEY,
#       não é consumida.
QWEN_OLLAMA_MODEL=qwen2.5:14b
OLLAMA_BASE_URL=http://localhost:11434

# ================================================================
# Azure Blob Storage (opcional — fallback CSV local se ausente)
# ================================================================
# Container 'dataset' guarda cardiac_data.csv + consultas_<paciente>.json
# Sem essa var, /monitor e /analise leem dashboard/data/cardiac_data.csv local
# e agendar_teleconsulta grava só no disco (sem dual-write Blob).
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net

# ================================================================
# Email alerts (opt-in — desabilitado por default)
# ================================================================
# Setar BLUA_EMAIL_ALERTS=enabled para ativar envio SMTP de alertas quando
# o /monitor detectar ≥4/5 batimentos irregulares na janela deslizante.
# Cooldown anti-spam: 300 segundos entre envios.
# SENHA_REMETENTE: gere App Password em https://myaccount.google.com/apppasswords
BLUA_EMAIL_ALERTS=disabled
EMAIL_REMETENTE=alertas@exemplo.com
SENHA_REMETENTE=xxxx-xxxx-xxxx-xxxx
EMAIL_DESTINATARIO_1=destinatario@exemplo.com

# ================================================================
# LangSmith observability (opcional)
# ================================================================
# Free tier: 5000 traces/mês — https://smith.langchain.com
#
# Duas formas de ativar (use UMA):
#  (a) Setar LANGSMITH_API_KEY — colab_setup.py deriva LANGCHAIN_* automaticamente
#  (b) Setar LANGCHAIN_* direto — SDK LangChain consome nativamente
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=blua-cardio
# Alternativa (b): descomente e preencha as 3 linhas abaixo
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls__xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LANGCHAIN_PROJECT=blua-cardio

# ================================================================
# RAG / ChromaDB
# ================================================================
CHROMA_PERSIST_DIR=./chroma_db

# ================================================================
# Pre-safety LLM validator (opcional)
# ================================================================
# Default "1" (ativo). Liga validador LLM extra no pre_safety chain — custa
# ~$0.0003 por mensagem suspeita (~5% do tráfego). Desligar com "0" em CI/tests
# pra evitar consumo de DashScope.
PRE_SAFETY_LLM_VALIDATOR=1

# ================================================================
# Path overrides (raramente alterado)
# ================================================================
# Override de raiz do projeto (útil em Docker/CI com volumes montados)
# BLUA_ROOT=/caminho/customizado
# BLUA_TELEMETRY_CSV=/caminho/cardiac_data.csv
# BLUA_GABRIEL_CSV=/caminho/gabriel_data.csv
# BLUA_MEU_PERFIL_CSV=/caminho/meu_perfil_data.csv
